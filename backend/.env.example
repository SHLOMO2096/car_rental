# Local dev settings — copied from .env.example
DATABASE_URL=sqlite:///./test_bootstrap.db
SECRET_KEY=dev-secret-key-change-in-production
FRONTEND_URL=http://localhost:5173
DEBUG=true

# Email Configuration (SMTP)
EMAILS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM=your-email@gmail.com
EMAILS_FROM_NAME="וואי קאר"

# Security Alerts
SECURITY_ALERT_RECIPIENTS=admin@example.com
CROSS_AGENT_BOOKING_EDIT_ALERTS_ENABLED=true

# Google Drive (car photos)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CREDENTIALS_JSON=
