# ─────────────────────────────────────────────────────────────────────────────
# Development environment – copy to .env.development and fill in real values
# Location on server: /opt/car-rental-dev/.env.development
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_RANDOM_HEX_32      # openssl rand -hex 32
FRONTEND_URL=http://YOUR_DEV_SERVER_IP:5173
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# Matches the postgres service defined in docker-compose.yml
DATABASE_URL=postgresql://postgres:devpassword@db:5432/carrental

# ── Auth / JWT ────────────────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_URL=redis://redis:6379/0

# ── Email (disabled on dev by default) ────────────────────────────────────────
EMAILS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM=noreply@carrental.co.il
EMAILS_FROM_NAME=וואי קאר - דב

# ── Google Drive (disabled on dev by default) ─────────────────────────────────
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CREDENTIALS_JSON=

